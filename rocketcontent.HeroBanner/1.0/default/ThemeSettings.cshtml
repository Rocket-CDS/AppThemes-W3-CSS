@inherits RocketCatalog.Components.RocketCatalogTokens<Simplisity.SimplisityRazor>
@using RocketCatalog.Components;
@using DNNrocketAPI.Components;
@using Simplisity;
@using RocketContent.Components;

@{
    var appThemeAdmin = (AppThemeLimpet)Model.GetDataObject("appthemeadmin");
    var moduleData = (ModuleContentLimpet)Model.GetDataObject("modulesettings");
    var info = new SimplisityInfo(moduleData.Record);

    AddProcessDataResx(appThemeAdmin);
    AddProcessData("resourcepath", "/DesktopModules/DNNrocketModules/RocketContent/App_LocalResources/");

    //NOTE: xPath for module settings must use "genxml/settings/*"
}

<div class="w3-third w3-padding">
    <label>@ResourceKey("DNNrocket.imageresize") (px)</label>
    @TextBox(info, "genxml/settings/imgresize", " class='w3-input w3-border'", "1400")
</div>
<div class="w3-third w3-padding">
    <label>@ResourceKey("DNNrocket.height") (px)</label>
    @TextBox(info, "genxml/settings/height", " class='w3-input w3-border'", "200")
</div>
<div class="w3-third w3-padding">
    <label>@ResourceKey("DNNrocket.width") (px)</label>
    @TextBox(info, "genxml/settings/width", " class='w3-input w3-border'", "700")
</div>


<script>

    $(document).ready(function () {
    });

</script>
