@inherits RocketDirectoryAPI.Components.RocketDirectoryAPITokens<Simplisity.SimplisityRazor>
@using DNNrocketAPI.Components;
@using RocketDirectoryAPI.Components;
@AssignDataModel(Model)
@AddProcessDataResx(appTheme, true)
@AddProcessData("resourcepath", "/DesktopModules/DNNrocketModules/RocketDirectoryAPI/App_LocalResources/")
<!--inject-->
<div class="rocket-categories" style="padding-right:8px;padding-left:8px;padding-top:@(moduleData.GetSetting("toppadding"))px;padding-bottom:@(moduleData.GetSetting("bottompadding"))px;">

    <div class="w3-bar-block">
        <a href="@ListUrl(moduleData.ListPageTabId())" onclick="w3shared_clearFiltersCategories('w3-theme-l3');" class="w3-bar-item w3-button w3-theme-l5 w3-hover-theme  w3-padding-small rocket-categorylink">@ResourceKey("DNNrocket.all")</a>

        @foreach (var catData in categoryDataList.GetCategoryTree())
        {
            if (!catData.Hidden && !catData.HiddenByCulture && catData.Level == 0)
            {
                var selectedCat = "";
                if (catData.CategoryId == categoryData.CategoryId)
                {
                    selectedCat = " w3-theme-l3 ";
                }

                <a href="@ListUrl(moduleData.ListPageTabId(), catData)" onclick="w3shared_clearFiltersCategories('w3-theme-l3');" class="w3-bar-item w3-button w3-theme-l5 w3-hover-theme  w3-padding-small rocket-categorylink @selectedCat">@catData.Name (@catData.GetArticles().RecordCount)</a>

                var l = catData.GetDirectChildren();
                if (l.Count > 0)
                {
                    <div class="w3-bar-block w3-margin-left">
                        @foreach (var child in l)
                        {
                            if (!child.Hidden && !child.HiddenByCulture)
                            {
                                selectedCat = "";
                                if (child.CategoryId == categoryData.CategoryId)
                                {
                                    selectedCat = " w3-theme-l3 ";
                                }
                                <a href="@ListUrl(moduleData.ListPageTabId(), child)" onclick="w3shared_clearFiltersCategories('w3-theme-l3');" class="w3-bar-item w3-button w3-theme-l5 w3-hover-theme w3-small w3-padding-small rocket-categorylink @selectedCat">@child.Name (@child.GetArticles().RecordCount)</a>
                            }
                        }
                    </div>
                }
            }
        }
    </div>
</div>

@if (categoryData != null  && categoryData.CategoryId > 0)
{
    <script>
        $(document).ready(function () {
            var element_to_scroll_to = document.getElementById('rocket@(appTheme.PrefixName)display');
            element_to_scroll_to.scrollIntoView();
        });
    </script>
}