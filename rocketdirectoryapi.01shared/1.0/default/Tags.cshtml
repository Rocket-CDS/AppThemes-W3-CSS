@inherits RocketDirectoryAPI.Components.RocketDirectoryAPITokens<Simplisity.SimplisityRazor>
@using DNNrocketAPI.Components;
@using RocketDirectoryAPI.Components;
@AssignDataModel(Model)
@AddProcessDataResx(appTheme, true)
@AddProcessData("resourcepath", "/DesktopModules/DNNrocketModules/RocketDirectoryAPI/App_LocalResources/")
<!--inject-->
@{
    var displayList = new List<int>();
}
<div class="rocket-tags w3-small" style="padding-right:8px;padding-left:8px;padding-top:@(moduleData.GetSetting("toppadding"))px;padding-bottom:@(moduleData.GetSetting("bottompadding"))px;">
    <div class="w3-row-padding">
        @foreach (var g in moduleData.GetPropertyModuleGroups(catalogSettings))
        {
            foreach (var p in propertyDataList.GetPropertyTagList(g.Key))
            {
                if (!displayList.Contains(p.Key))
                {
                    <span class="w3-margin-right w3-margin-bottom w3-show-inline-block">
                        @TagButton(p.Key, p.Value, sessionParams, "w3-theme-l5","w3-theme-l3")
                    </span>
                    displayList.Add(p.Key);
                }
            }
        }
    <span class="w3-margin-top">
        @TagButtonClear("X", sessionParams, "w3-theme-l5")
    </span>

    </div>
</div>

@TagJsApiCall(moduleData,"#rocket-" + appTheme.PrefixName, sessionParams, "w3-theme-l5", "w3-theme-l3", "articlelist.cshtml")

<script>
    $(document).ready(function () {
        $(".rocket-tagbutton").on("click", function () {
            var element_to_scroll_to = document.getElementById('rocket@(appTheme.PrefixName)display');
            if (element_to_scroll_to)
            {
                element_to_scroll_to.scrollIntoView();
            }
        });
    });
</script>