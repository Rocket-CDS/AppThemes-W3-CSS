@inherits RocketEventsAPI.Components.RocketEventsAPITokens<Simplisity.SimplisityRazor>
@using DNNrocketAPI.Components;
@using RocketDirectoryAPI.Components;
@AssignDataModel(Model)
@AddProcessDataResx(appTheme, true)
@AddProcessData("resourcepath", "/DesktopModules/DNNrocketModules/RocketDirectoryAPI/App_LocalResources/")
<!--inject-->
@{
    var eventDate = article.Info.GetXmlPropertyDate("genxml/textbox/eventstartdate");
}
@if (!String.IsNullOrEmpty(article.Name))
{
    <div class="@paddingClass">
        <p class="@moduleData.GetSetting("titlesize") w3-margin-bottom w3-text-dark-grey">
            <span><b>@article.Name</b></span><br />
            <span class="w3-opacity">@DateOf(eventDate, sessionParams.CultureCode, "dd MMM yyy")</span>
        </p>
    </div>
}
@if (!String.IsNullOrEmpty(article.Summary))
{
    <p class="@moduleData.GetSetting("textsize") @paddingClass w3-text-grey">
        @BreakOf(article.Summary)
    </p>
}

<div class="w3-row @paddingClass">
    <a href="@DetailUrl(moduleData.DetailPageTabId(), article, categoryData)#rocketeventsdisplay" onclick="$('.simplisity_loader').show();" class="w3-button w3-theme-l5 w3-text-dark-grey w3-border w3-border-light-grey w3-round-xlarge w3-hover-white aboutlink" title="@article.Name">
        <b>@ResourceKey("Events.readmore")&nbsp;&gt;&nbsp;</b>
    </a>
</div>
